// Copier ce fichier en Secrets.xcconfig (non versionné) et compléter les valeurs.

// Apple Developer Team ID — visible dans Xcode → Settings → Accounts.
DEVELOPMENT_TEAM = YOUR_TEAM_ID

// Géoplateforme IGN — clé API gratuite sur https://geoservices.ign.fr
IGN_API_KEY = your_ign_api_key

// Strava API — créer l'app sur https://www.strava.com/settings/api
STRAVA_CLIENT_ID = your_strava_client_id
STRAVA_CLIENT_SECRET = your_strava_client_secret

// Bunny Storage — publication des pages sur gpxmanagement.net.
// Nom de la zone de stockage (PAS l'ID numérique du dashboard), sa région, et la clé d'accès (mot de passe Storage).
// Région : laisser vide pour Falkenstein (par défaut), sinon le préfixe (ny, la, sg, syd, uk, se, br, jh).
BUNNY_STORAGE_ZONE = your_storage_zone_name
BUNNY_STORAGE_REGION =
BUNNY_STORAGE_KEY = your_storage_access_key
